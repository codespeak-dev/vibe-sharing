{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "types": ["wicg-file-system-access", "sql.js"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
